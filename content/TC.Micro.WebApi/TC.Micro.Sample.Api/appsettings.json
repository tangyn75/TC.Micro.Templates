{
  "MicroService": {
    "ServiceName": "sample",
    "Version": "1.0.0",
    "Host": "localhost",
    "Port": 5400
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceName": "sample",
    "ServiceId": "sample-1",
    "ServiceHost": "localhost",
    "ServicePort": 5400,
    "HealthCheckUrl": "http://localhost:5400/health",
    "DeregisterCriticalServiceAfter": "1m"
  },
  "Jwt": {
    "PublicKeyPath": "<从 Consul KV TC.Micro/{Env}/Identity/JwtPublicKey 读取>",
    "Issuer": "TC.Micro.Identity",
    "Audience": "TC.Micro.Services",
    "ValidateLifetime": true
  },
  "GatewaySignature": {
    "SigningKeyPath": "<从 Consul KV TC.Micro/{Env}/Gateway/SigningSecret 读取>",
    "TimestampToleranceSeconds": 30
  },
  "Messaging": {
    "Provider": "RabbitMQ"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "<从 Consul KV 读取>",
    "VirtualHost": "/",
    "ExchangeName": "TC.Micro.Events"
  },
  "Dtm": {
    "DtmUrl": "http://localhost:36789/api/dtmsvr"
  },
  "Cache": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "TC.Micro:"
  },
  "Tracing": {
    "Enabled": true,
    "ServiceName": "sample",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "HealthChecks": {
    "EnableConsul": true,
    "EnableRedis": true,
    "EnableRabbitMQ": true,
    "EnablePostgres": true
  },
  "OpenApi": {
    "Title": "Sample API",
    "Version": "v1",
    "Description": "TC.Micro 业务服务 API"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=sample_db;Username=tc_micro;Password=<从 Consul KV 读取>"
  }
}
