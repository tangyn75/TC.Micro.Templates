@inject IThemeService ThemeService
@inject NavigationManager Nav

<MudAppBar Elevation="1" Dense="false" Color="Color.Surface">

    <!-- 左侧：菜单切换 + Logo（仅桌面端显示 Logo） -->
    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                   Color="Color.Inherit"
                   Edge="Edge.Start"
                   OnClick="@OnMenuToggle" />
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="ml-2 mr-4">
            <MudIcon Icon="@Icons.Material.Filled.CloudDone"
                     Size="Size.Medium"
                     Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight:600">TC.Micro Admin</MudText>
        </MudStack>
    </MudHidden>

    <MudSpacer />

    <!-- 主题切换（明/暗） -->
    <MudTooltip Text="@(ThemeService.IsDarkMode ? "切换亮色模式" : "切换暗色模式")">
        <MudIconButton Icon="@(ThemeService.IsDarkMode
                                ? Icons.Material.Filled.LightMode
                                : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ThemeService.ToggleDarkMode" />
    </MudTooltip>

    <!-- 用户信息 -->
    <MudMenu Icon="@Icons.Material.Filled.AccountCircle"
             Color="Color.Inherit"
             Direction="Direction.Bottom"
             OffsetY="true"
             Dense="true">
        <MudMenuItem Icon="@Icons.Material.Outlined.Person">个人资料</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Outlined.Settings">设置</MudMenuItem>
        <MudDivider />
        <MudMenuItem Icon="@Icons.Material.Outlined.Logout"
                     OnClick="@(() => Nav.NavigateTo("/login", forceLoad: true))">
            退出登录
        </MudMenuItem>
    </MudMenu>

</MudAppBar>

@code {
    [Parameter] public EventCallback OnMenuToggle { get; set; }
}
