@inject IThemeService ThemeService

<MudAppBar Elevation="1" Dense="false" Color="Color.Surface">

    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                   Color="Color.Inherit"
                   Edge="Edge.Start"
                   OnClick="@OnMenuToggle" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="ml-2 mr-4">
        <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" />
        <MudText Typo="Typo.h6" Style="font-weight:600">Sample Admin</MudText>
    </MudStack>

    <MudSpacer />

    <!-- 明/暗主题切换 -->
    <MudTooltip Text="@(ThemeService.IsDarkMode ? "切换亮色" : "切换暗色")">
        <MudIconButton
            Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
            Color="Color.Inherit"
            OnClick="@ThemeService.ToggleDarkMode" />
    </MudTooltip>

</MudAppBar>

@code {
    [Parameter] public EventCallback OnMenuToggle { get; set; }
}
